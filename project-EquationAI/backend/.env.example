# ═══════════════════════════════════════════════════
# EquationAI — Environment Configuration Template
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════

# ── Application ──
FASTAPI_ENV=development          # development | production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
DEBUG=true

# ── Database ──
DATABASE_URL=sqlite:///./equations.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/equationai

# ── JWT Authentication ──
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ── File Storage ──
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
FILE_CLEANUP_TTL_HOURS=24

# ── Vector DB ──
CHROMA_DB_PATH=./vector_db/data
CHROMA_COLLECTION_NAME=equations_collection

# ── Logging ──
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/equationai.log
