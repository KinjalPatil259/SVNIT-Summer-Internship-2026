# Backend Configuration
FASTAPI_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
DEBUG=true

# Database Configuration
DATABASE_URL=sqlite:///./equations.db

# JWT Authentication
SECRET_KEY=equationai-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Origins (comma-separated in env, but we use defaults in Settings)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
FILE_CLEANUP_TTL_HOURS=24

# Vector DB Configuration
CHROMA_DB_PATH=./vector_db/data
CHROMA_COLLECTION_NAME=equations_collection

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/equationai.log
